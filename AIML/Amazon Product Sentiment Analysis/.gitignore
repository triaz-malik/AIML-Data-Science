*.py[cod]
.venv/
venv/
env/
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# NLTK / HF caches
.cache/
nltk_data/

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
